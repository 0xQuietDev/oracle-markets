# ORACLE — Avalanche Fuji environment (chainId 43113)
# Copy to .env.fuji and fill with funded keys. NEVER commit .env.fuji (gitignored).
# Generate a fresh set with:  cast wallet new-mnemonic  then derive indices 0..9.

# Deployer (index 0) — needs AVAX gas to deploy ValidationRegistry + OracleCore
FUJI_DEPLOYER_KEY=0x...

# Fleet signers (each needs a little AVAX for gas; funded roles also need USDC)
FUJI_CLIENT_KEY=0x...          # posts tasks, escrows reward (needs USDC)
FUJI_WORKER_KEY=0x...          # self-stake + x402 spend (needs USDC)
FUJI_VALIDATOR_KEY=0x...       # posts validationResponse (needs AVAX only)
FUJI_BETTORREP_KEY=0x...       # bets + buys trust feed (needs USDC)
FUJI_BETTORSKEPTIC_KEY=0x...   # bets NO (needs USDC)
FUJI_BETTORMIRROR_KEY=0x...    # follows the money (needs USDC)
FUJI_VENDOR_KEY=0x...          # sells x402 task input (needs AVAX only)
FUJI_REVENUE_KEY=0x...         # ORACLE_REVENUE_WALLET, receives x402 fees
FUJI_RELAYER_KEY=0x...         # only if self-hosting a facilitator (needs AVAX)

# x402 facilitator (try in order; first that settles on Fuji wins — see docs/FUJI.md)
X402_FACILITATOR=https://facilitator.payai.network

# Set when running any process against Fuji
ORACLE_DEPLOYMENT=deployments/fuji.json
ORACLE_REVENUE_WALLET=0x...    # = address of FUJI_REVENUE_KEY
